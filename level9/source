class N {
public:
    
    void**  vtable;
    char    buffer[100];
    int     value;

    virtual int operator+(N& other);
    virtual int operator-(N& other);
};

void N::setAnnotation(N *this, char *str)
{
  size_t n;
  
  n = strlen(str);
  memcpy(this->buffer, str, n);
  return;
}

void N::N(N *this, int n)
{
    this->vtable = &PTR_operator+_08048848;
    this->value = n;
    return;
}

int N::operator+(N *this, N *other)
{
    return other->value + this->value;
}

int N::operator-(N *this, N *other)
{
    return other->value - this->value;
}

void main(int ac, char **av)
{
    N *obj1;
    N *obj2;
    
    if (ac < 2) {
        _exit(1);
    }

    obj1 = operator.new(0x6c);
    N::N(obj1,5);
    obj2 = operator.new(0x6c);
    N::N(obj2,6);
    
    N::setAnnotation(obj1,av[1]);
    
    (**obj2->vtable)(obj1);
    
    return;
}
