int main(int ac, char **av)
{
    FILE *stream = fopen("/home/user/end/.pass", "r");

    if (stream == 0)
        return (-1);

    if (ac != 2)
        return (-1);

    char buf[132];

    memset(buf, 0, 0x21 * 4);

    fread(buf, 1, 66, stream);

    buf[atoi(av[1])] = '\0';

    fread(buf + 66, 1, 65, stream);

    fclose(stream);

    if (strcmp(buf, av[1]) != 0)
        puts();
    else
        execl("/bin/sh", "sh", 0);

    return (0);
}
