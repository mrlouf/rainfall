int main(int ac, char *av[]) {

    if (atoi(av[1]) != 423) {
        fwrite("No !", 1, 5, stdout);
        return 0;
    }

    char *str = strdup("/bin/sh");
    gid_t egid = getegid();
    uid_t euid = geteuid();

    setresgid(egid, egid, egid);
    setresuid(euid, euid, euid);

    char *const args[] = {str, NULL};

    execv(str, args);
    return 0;
}
