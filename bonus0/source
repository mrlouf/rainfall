void p(char *dest, char const *dash)
{
    char buf[4096];

    puts(dash);
    read(0, buf, 4096);

    *strchr(buf, '\n') = '\0'; // '\n' = 0xa

    strncpy(dest, buf, 20);
    return;
}

void pp(char *str) {

    char s1[20];
    char s2[20];

    p(s1, " - ");
    p(s2, " - ");

    strcpy(str, s1);

    size_t len = strlen(str);

    str[len] = ' ';
    str[len + 1] = '\0';

    strcat(str, s2);
}

int main()
{
    char str[42];

    pp(str);
    puts(str);
}
