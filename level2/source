void p( void )
{
    char buffer[76];

    fflush(stdout);
    gets(buffer); // overflow possible

    void *ret = __builtin_return_address(0);

    if ( (ret & 0xb0000000) == 0xb0000000) {
        printf("(%p)\n", ret);
        _exit(1);
    }

    puts(buffer);
    strdup("/bin/sh");
	return;
}

void main( void )
{
    p();
}
